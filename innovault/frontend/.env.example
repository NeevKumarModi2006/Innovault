# ============================================================
#  INNOVAULT — FRONTEND ENVIRONMENT CONFIGURATION
# ============================================================
#  Copy this file to .env and fill in your values.
#  All variables MUST be prefixed with VITE_ to be exposed to the browser.
#  Never commit your real .env file to version control.
# ============================================================

# ── API Base URL ─────────────────────────────────────────────
# LOCAL: point to your local backend server
VITE_API_URL=http://localhost:3000

# DEPLOYED: comment out the local line above and use your deployed backend URL
# VITE_API_URL=https://your-backend-domain.com

# ── App Meta ─────────────────────────────────────────────────
VITE_APP_NAME=Innovault
