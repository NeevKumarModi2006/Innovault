# ============================================================
#  INNOVAULT — BACKEND ENVIRONMENT CONFIGURATION
# ============================================================
#  Copy this file to .env and fill in your values.
#  Never commit your real .env file to version control.
# ============================================================

# ── Server ──────────────────────────────────────────────────
PORT=3000

# ── Database ─────────────────────────────────────────────────
# LOCAL: use the line below (MongoDB running on your machine)
DATABASE_URL=mongodb://localhost:27017/innovault

# ATLAS (cloud): comment out the local line above and use this instead.
# Replace <username>, <password>, and <cluster-url> with your Atlas credentials.
# Found in: Atlas Dashboard → Your Cluster → Connect → Drivers
# DATABASE_URL=mongodb+srv://Innovault:<db_password>@.....

# ── Authentication ───────────────────────────────────────────
# Use a long random string. Generate one with: node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
JWT_SECRET=replace_this_with_a_long_random_secret
# Token expiry (e.g. 7d, 24h, 30m)
JWT_EXPIRES_IN=7d


# ── CORS ─────────────────────────────────────────────────────
# LOCAL: http://localhost:5173  |  DEPLOYED: https://your-frontend-domain.com
CLIENT_ORIGIN=http://localhost:5173

# ── Node Environment ─────────────────────────────────────────
# LOCAL: development  |  DEPLOYED: production
NODE_ENV=development

# ── Email Service (SMTP) ─────────────────────────────────────
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=your_email@gmail.com
SMTP_PASS=your_app_password
FROM_EMAIL=no-reply@innovault.com

# ── Review Moderation ────────────────────────────────────────
# Number of reports before a review is auto-hidden (default: 20)
REPORT_THRESHOLD=20

# ── Cloudinary (Image Uploads) ───────────────────────────────
# Sign up at https://cloudinary.com (free 25GB)
# Leave ALL THREE blank to fall back to local disk storage.
CLOUDINARY_CLOUD_NAME=your_cloudinary_cloud_name
CLOUDINARY_API_KEY=your_cloudinary_api_key
CLOUDINARY_API_SECRET=your_cloudinary_api_secret

# ── Redis (Caching) ──────────────────────────────────────────
# Sign up at https://redis.com/try-free (free 30MB)
# Leave blank to bypass caching — app works fine without it.
REDIS_URL=rediss://default:your_redis_password@your_redis_host:port

# ── QStash (Upstash Serverless Messaging) ─────────────────
# Sign up at https://upstash.com (free 500 msg/day)
# Replaces the deprecated Upstash Kafka service.
# Leave QSTASH_TOKEN blank to gracefully bypass messaging locally.
QSTASH_URL=https://qstash.upstash.io/api/v1
QSTASH_TOKEN=your_qstash_token

# Webhook Security Keys (Found in Upstash Dashboard -> QStash -> exact same page as Token)
# Required only if you are receiving webhooks securely.
QSTASH_CURRENT_SIGNING_KEY=your_current_signing_key
QSTASH_NEXT_SIGNING_KEY=your_next_signing_key

# Optional: URL where QStash delivers events (your own webhook, logging service, etc.)
# Eg. in production: https://your-backend.onrender.com/api/webhooks/qstash
# If blank, events are published to a QStash topic for later consumption.
QSTASH_RECEIVER_URL=https://your-backend.onrender.com/api/webhooks/qstash
